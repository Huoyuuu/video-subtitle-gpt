#!/usr/bin/env bash
set -euo pipefail
APP=/home/huoyuuu/video-subtitle-gpt
BRANCH=main
while read oldrev newrev refname; do
  [ "$refname" = "refs/heads/$BRANCH" ] || continue
  echo "Deploy hook: deploying $refname to $APP"
  unset GIT_DIR GIT_WORK_TREE
  if [ ! -d "$APP/.git" ]; then
    rm -rf "$APP"
    git clone /home/huoyuuu/gitea/repositories/huoyuuu/video-subtitle-gpt.git "$APP"
  fi
  cd "$APP"
  git fetch origin "$BRANCH"
  git reset --hard "origin/$BRANCH"
  find "$APP" -type f \( -name '*.sh' -o -name '*.service' -o -name '*.example' \) -exec sed -i 's/\r$//' {} +
  [ -f .env ] || cp .env.example .env
  chmod +x scripts/deploy.sh || true
  bash scripts/deploy.sh
  echo "Deploy hook: deployed $refname to $APP"
done
