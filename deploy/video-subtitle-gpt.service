[Unit]
Description=Video Subtitle GPT FastAPI
After=network.target

[Service]
Type=simple
User=huoyuuu
Group=huoyuuu
WorkingDirectory=/home/huoyuuu/video-subtitle-gpt
EnvironmentFile=/home/huoyuuu/video-subtitle-gpt/.env
ExecStart=/home/huoyuuu/video-subtitle-gpt/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 18004
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target


